# Copy this file to .env and fill in your values.
# Never commit .env to version control.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets CRM integration (Phase 5)
# Paste the CSV export URL from your Google Sheet here.
# Format: https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0
# Leave blank to fall back to sample data/crm_leads.csv
STREAMLIT_GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vSbzGQC_7atqkbRSKgStwcJoaDoATGCqn1Sc2SUJsdf7oYnm-hhrJaMfNNNFQFGcwucm94vSf39cG6L/pub?output=csv

# Optional: override default paths
DATA_DIR=data
OUTPUT_DIR=output
